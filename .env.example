# Supabase Configuration
VITE_SUPABASE_URL=your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Encryption key for API key storage (optional, use a long random string in production)
VITE_ENCRYPTION_KEY=your-encryption-key-here

# Note: Gemini/OpenAI/Anthropic API keys are managed by users in app Settings (not here)
